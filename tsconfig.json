{
  "compilerOptions": {
    "target": "es2016",
    "module": "Node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": "./src",
    "paths": {
      "@entity/*": ["entity/*"],
      "@use_case/*": ["use_case/*"],
      "@adapter/*": ["adapter/*"],
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"],
}